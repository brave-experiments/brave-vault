{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Brave Vault",
  "version": "0.1.0",
  "identifier": "com.brave.vault",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Brave Vault",
        "width": 1040,
        "height": 680,
        "minWidth": 800,
        "minHeight": 520,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
